{% extends 'base.html.twig' %}

{% block title %}{{ offre.titre }} - Détails{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1>Offre : {{ offre.titre }}</h1>

        <div class="mb-3">
            <strong>Type :</strong> {{ offre.type.libelle }}
        </div>

        <div class="mb-3">
            <strong>Description :</strong> <br>
            <p>{{ offre.description }}</p>
        </div>

        <div class="mb-3">
            <strong>Date de publication :</strong> {{ offre.date ? offre.date|date('d/m/Y') : '' }}
        </div>

        <div class="mb-3">
            <strong>Publié par :</strong> {{ offre.user.username }}
        </div>

        <div class="mt-4">
            <a href="{{ path('offre_edit', {'id': offre.id}) }}" class="btn btn-warning">✏️ Modifier</a>
            {{ include('offre/_delete_form.html.twig', {'offre': offre}) }}
            <a href="{{ path('offre_index') }}" class="btn btn-secondary">← Retour à la liste</a>
        </div>
    </div>
{% endblock %}
``
