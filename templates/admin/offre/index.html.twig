{% extends 'base.html.twig' %}

{% block title %}Liste des offres{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1 class="mb-4">Toutes les offres</h1>

        <a href="{{ path('offre_new') }}" class="btn btn-success mb-3">➕ Nouvelle offre</a>

        <table class="table table-bordered table-striped">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Titre</th>
                    <th>Type</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for offre in offres %}
                    <tr>
                        <td>{{ offre.id }}</td>
                        <td>{{ offre.titre }}</td>
                        <td>{{ offre.type.libelle }}</td>
                        <td>{{ offre.date ? offre.date|date('d/m/Y') : '' }}</td>
                        <td>
                            <a href="{{ path('offre_show', {'id': offre.id}) }}" class="btn btn-sm btn-info">👁 Voir</a>
                            <a href="{{ path('offre_edit', {'id': offre.id}) }}" class="btn btn-sm btn-warning">✏️ Modifier</a>
                            {{ include('offre/_delete_form.html.twig', {'offre': offre}) }}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center">Aucune offre trouvée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
