{% extends 'base.html.twig' %}

{% block title %}Modifier le statut de la candidature{% endblock %}

{% block body %}
    <div class="container mt-5">
        <h1>Modifier le statut de la candidature pour : {{ candidature.user.username }}</h1>

        {{ form_start(form) }}
            <div class="mb-3">
                {{ form_label(form.statut) }}
                {{ form_widget(form.statut, {'attr': {'class': 'form-select'}}) }}
                {{ form_errors(form.statut) }}
            </div>

            <button class="btn btn-primary">Enregistrer</button>
        {{ form_end(form) }}

        <a href="{{ path('candidature_show', {'id': candidature.id}) }}" class="btn btn-secondary mt-3">← Retour aux détails</a>
    </div>
{% endblock %}
